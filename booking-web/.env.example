# URL e anon key do mesmo projeto Supabase do app Barber Pro
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# npm run dev: o Vite usa proxy para /functions/v1 (evita CORS). Reinicie o dev server se mudar este arquivo.

# Deve ser o mesmo fuso configurado na Edge Function (secret BOOKING_TIMEZONE), padrão America/Sao_Paulo
VITE_BOOKING_TIMEZONE=America/Sao_Paulo
